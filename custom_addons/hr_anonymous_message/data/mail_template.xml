<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            This template is kept for XML ID reference integrity only.
            It is NOT used for sending emails. The only email sent by this
            module is the monthly cron report (hr_anonymous_message.py →
            _cron_send_monthly_report), which builds its email body directly
            in Python and sends via mail.mail with an Excel attachment.
        -->
        <record id="email_template_anonymous_message" model="mail.template">
            <field name="name">Anonymous Message — Monthly Report (System)</field>
            <field name="model_id" ref="model_hr_anonymous_message"/>
            <field name="subject">Monthly Anonymous Messages Report</field>
            <field name="email_from">{{user.email or 'noreply@localhost'}}</field>
            <field name="body_html"><![CDATA[
                <p>This template is not used directly.
                   The monthly report is generated and sent by the scheduled cron job.</p>
            ]]></field>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>