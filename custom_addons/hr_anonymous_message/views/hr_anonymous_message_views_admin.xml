<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ADMIN SEARCH VIEW  (sidebar — same fields + audit hash search) -->
        <record id="view_hr_anonymous_message_search_admin" model="ir.ui.view">
            <field name="name">hr.anonymous.message.search.admin</field>
            <field name="model">hr.anonymous.message</field>
            <field name="priority">5</field>
            <field name="arch" type="xml">
                <search string="Search Messages (Admin)">

                    <field name="name" string="Subject"
                           filter_domain="[('name', 'ilike', self)]"/>
                    <field name="category_id" string="Category"/>
                    <field name="sender_audit_hash" string="Audit Hash"
                           filter_domain="[('sender_audit_hash', '=', self)]"
                           groups="base.group_system"/>

                    <filter string="Urgent" name="filter_urgent"
                            domain="[('priority', '=', '3')]"/>
                    <filter string="High Priority" name="filter_high"
                            domain="[('priority', '=', '2')]"/>
                    <filter string="Normal" name="filter_normal"
                            domain="[('priority', '=', '1')]"/>
                    <filter string="Low" name="filter_low"
                            domain="[('priority', '=', '0')]"/>

                    <separator/>

                    <filter string="New / Sent" name="filter_sent"
                            domain="[('state', '=', 'sent')]"/>
                    <filter string="Acknowledged" name="filter_acknowledged"
                            domain="[('state', '=', 'acknowledged')]"/>
                    <filter string="In Progress" name="filter_in_progress"
                            domain="[('state', '=', 'in_progress')]"/>
                    <filter string="Resolved" name="filter_resolved"
                            domain="[('state', '=', 'resolved')]"/>
                    <filter string="Declined" name="filter_declined"
                            domain="[('state', '=', 'declined')]"/>
                    <filter string="Closed by Employee" name="filter_closed"
                            domain="[('state', '=', 'closed')]"/>
                    <filter string="Draft (unsent)" name="filter_draft"
                            domain="[('state', '=', 'draft')]"/>

                    <separator/>

                    <filter string="Needs Attention" name="filter_needs_attention"
                            domain="[('state', 'in', ['sent', 'acknowledged'])]"/>
                    <filter string="Active Cases" name="filter_active"
                            domain="[('state', 'in', ['sent', 'acknowledged', 'in_progress'])]"/>
                    <filter string="Completed" name="filter_completed"
                            domain="[('state', 'in', ['resolved', 'declined', 'closed'])]"/>
                    <filter string="Email Sent" name="filter_mail_sent"
                            domain="[('mail_sent', '=', True)]"/>

                    <separator/>

                    <filter string="Date Received" name="filter_create_date"
                            date="create_date"/>
                    <filter string="This Month" name="filter_this_month"
                            domain="[('create_date', '&gt;=',
                                      context_today().strftime('%Y-%m-01'))]"/>
                    <filter string="Last Month" name="filter_last_month"
                            domain="[('create_date', '&gt;=',
                                      (context_today() - relativedelta(months=1)).strftime('%Y-%m-01')),
                                     ('create_date', '&lt;',
                                      context_today().strftime('%Y-%m-01'))]"/>

                    <!-- ── Group By ── -->
                    <group expand="0" string="Group By">
                        <filter string="Category"       name="group_category"  context="{'group_by': 'category_id'}"/>
                        <filter string="Status"         name="group_state"     context="{'group_by': 'state'}"/>
                        <filter string="Priority"       name="group_priority"  context="{'group_by': 'priority'}"/>
                        <filter string="Month Received" name="group_month"     context="{'group_by': 'create_date:month'}"/>
                    </group>

                    <!-- ── Search Panel (left sidebar) ── -->
                    <searchpanel>

                        <field name="category_id" string="Category" icon="fa-tag"
                               select="one" enable_counters="1"/>

                    </searchpanel>

                </search>
            </field>
        </record>

        <!-- ADMIN LIST VIEW  -->
        <record id="view_hr_anonymous_message_list_admin" model="ir.ui.view">
            <field name="name">hr.anonymous.message.list.admin</field>
            <field name="model">hr.anonymous.message</field>
            <field name="priority">5</field>
            <field name="arch" type="xml">
                <list string="All Messages (Admin)" create="0" edit="1" delete="1"
                      default_order="priority desc, create_date desc">
                    <field name="create_date" optional="show"/>
                    <field name="category_id" string="Category" optional="show"/>
                    <field name="name"/>
                    <field name="priority" widget="priority" optional="show"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'acknowledged'"
                           decoration-warning="state in ['sent']"
                           decoration-success="state == 'resolved'"
                           decoration-danger="state == 'declined'"
                           decoration-muted="state in ['closed', 'draft']"/>
                    <field name="is_closed_by_employee" optional="hide"/>
                    <field name="sender_audit_hash" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- ADMIN FORM VIEW -->
        <record id="view_hr_anonymous_message_form_admin" model="ir.ui.view">
            <field name="name">hr.anonymous.message.form.admin</field>
            <field name="model">hr.anonymous.message</field>
            <field name="priority">5</field>
            <field name="arch" type="xml">
                <form string="Anonymous Message (Admin)" create="0" edit="1" delete="1">
                    <header>
                        <button name="action_acknowledge" string="Acknowledge" type="object"
                                invisible="state != 'sent'"
                                groups="base.group_system"/>
                        <button name="action_in_progress" string="In Progress" type="object"
                                invisible="state not in ['sent', 'acknowledged']"
                                groups="base.group_system"/>
                        <button name="action_resolve" string="Resolve" type="object"
                                invisible="state != 'in_progress'"
                                groups="base.group_system"/>
                        <button name="action_decline" string="Decline" type="object"
                                invisible="state not in ['sent', 'acknowledged', 'in_progress']"
                                groups="base.group_system"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="category_id"/>
                                <field name="priority" widget="priority"/>
                                <field name="create_date"/>
                            </group>
                            <group>
                                <field name="is_closed_by_employee"/>
                                <field name="mail_sent"/>
                                <field name="sender_audit_hash" readonly="1"
                                       groups="base.group_system"/>
                            </group>
                        </group>
                        <group>
                            <field name="name" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Message">
                                <field name="description" widget="html" readonly="1"/>
                            </page>
                            <page string="HR Notes">
                                <field name="hr_notes"/>
                            </page>
                            <page string="Resolution">
                                <field name="resolution_notes"/>
                            </page>
                        </notebook>
                        <field name="closed_date" invisible="1"/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ADMIN ACTION  — wired to admin search view -->
        <record id="action_hr_anonymous_message_admin" model="ir.actions.act_window">
            <field name="name">All Messages (Admin)</field>
            <field name="res_model">hr.anonymous.message</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id"
                   ref="view_hr_anonymous_message_search_admin"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No anonymous messages
                </p>
                <p>
                    System administrator view with audit capabilities.
                </p>
            </field>
        </record>

        <record id="action_hr_anonymous_message_admin_view_list"
                model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_hr_anonymous_message_list_admin"/>
            <field name="act_window_id" ref="action_hr_anonymous_message_admin"/>
        </record>

        <record id="action_hr_anonymous_message_admin_view_form"
                model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_hr_anonymous_message_form_admin"/>
            <field name="act_window_id" ref="action_hr_anonymous_message_admin"/>
        </record>

        <menuitem id="menu_anonymous_message_admin"
                  name="System Admin"
                  parent="menu_anonymous_message_root"
                  action="action_hr_anonymous_message_admin"
                  groups="base.group_system"
                  sequence="30"/>

    </data>
</odoo>