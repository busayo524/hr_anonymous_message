<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="group_hr_anonymous_staff" model="res.groups">
            <field name="name">HR Anonymous Staff</field>
            <field name="comment">This group is for HR staff can view and manage all anonymous HR messages. Not inherited by system admins.</field>
        </record>

         <!-- Record Rules -->

        <record id="hr_anonymous_message_rule_employee" model="ir.rule">
            <field name="name">Employee: Own Messages Only</field>
            <field name="model_id" ref="model_hr_anonymous_message"/>
            <field name="domain_force">[('sender_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="hr_anonymous_message_rule_hr_user" model="ir.rule">
            <field name="name">HR Anonymous Staff: All Messages</field>
            <field name="model_id" ref="model_hr_anonymous_message"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="hr_anonymous_message_rule_hr_staff" model="ir.rule">
            <field name="name">HR Anonymous Staff: All Messages</field>
            <field name="model_id" ref="model_hr_anonymous_message"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr_anonymous_message.group_hr_anonymous_staff'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="hr_anonymous_message_rule_admin" model="ir.rule">
            <field name="name">Admin: All Messages (Still Anonymous)</field>
            <field name="model_id" ref="model_hr_anonymous_message"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="hr_anonymous_message_audit_rule_admin" model="ir.rule">
            <field name="name">Admin: Audit Logs (Read Only)</field>
            <field name="model_id" ref="model_hr_anonymous_message_audit"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="hr_anonymous_message_category_rule_employee" model="ir.rule">
                    <field name="name">Employee: Read Categories Only</field>
                    <field name="model_id" ref="model_hr_anonymous_message_category"/>
                    <field name="domain_force">[(1, '=', 1)]</field>
                    <field name="groups" eval="[(4, ref('base.group_user'))]"/>
                    <field name="perm_read" eval="True"/>
                    <field name="perm_write" eval="False"/>
                    <field name="perm_create" eval="False"/>
                    <field name="perm_unlink" eval="False"/>
                </record>

        <record id="hr_anonymous_message_category_rule_hr" model="ir.rule">
            <field name="name">HR User: Manage Categories</field>
            <field name="model_id" ref="model_hr_anonymous_message_category"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="hr_anonymous_message_category_rule_hr_staff" model="ir.rule">
            <field name="name">HR Anonymous Staff: Manage Categories</field>
            <field name="model_id" ref="model_hr_anonymous_message_category"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr_anonymous_message.group_hr_anonymous_staff'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="hr_anonymous_message_category_rule_admin" model="ir.rule">
            <field name="name">Admin: Manage Categories</field>
            <field name="model_id" ref="model_hr_anonymous_message_category"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
    </data>
</odoo>